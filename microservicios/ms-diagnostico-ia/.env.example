APP_NAME=ms-diagnostico-ia
ENVIRONMENT=development
PORT=8000
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:8080

# === Proveedores de IA (triaje + analisis de imagen) ===
# Se intentan EN ESTE ORDEN; el primero con clave configurada atiende la peticion.
# Si ninguno tiene clave, se degrada a reglas locales (demo, confianza baja 0.35).
#   Solo OpenAI  -> deja GEMINI_API_KEY vacia (o pon IA_PROVIDER_ORDER=openai)
#   Solo Gemini  -> deja OPENAI_API_KEY vacia
#   Las dos      -> la segunda actua como respaldo si la primera falla
IA_PROVIDER_ORDER=gemini,openai

# Pega tu clave real solo en .env. Este archivo si se puede subir.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# OpenAI: reportes por voz (Whisper + chat), pre-triaje y analisis de imagen (vision).
# Con solo esta clave el microservicio funciona COMPLETO, sin necesidad de Gemini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
# Modelo multimodal para /api/analizar-imagen (gpt-4o-mini soporta vision).
OPENAI_VISION_MODEL=gpt-4o-mini

DATABASE_URL=sqlite:///./data/ms_ia.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=15

# sqlite mantiene el modo local. Usa dynamodb en Render/AWS.
STORAGE_BACKEND=sqlite
AWS_REGION=sa-east-1
DYNAMODB_TABLE=ms2_diagnostico_ia
S3_BUCKET=
S3_PREFIX=uploads
